#!/usr/bin/env python3
"""git-reword — reword commit messages interactively or via AI."""

import argparse
import json
import os
import re
import stat
import subprocess
import sys
import tempfile
from abc import ABC, abstractmethod
from dataclasses import dataclass
from pathlib import Path
from typing import Optional


# ── Schemas ────────────────────────────────────────────────────────────────────

COMMIT_SCHEMA = {
    "type": "object",
    "additionalProperties": False,
    "properties": {
        "message": {"type": "string", "minLength": 1},
    },
    "required": ["message"],
}

VERIFY_SCHEMA = {
    "type": "object",
    "additionalProperties": False,
    "properties": {"accurate": {"type": "boolean"}},
    "required": ["accurate"],
}


# ── Configuration ──────────────────────────────────────────────────────────────

@dataclass
class Config:
    since: str = "--root"
    auto: bool = False
    checkpoint: bool = False
    verbosity: int = 0
    verify: bool = False
    use_claude: bool = False
    claude_model: str = "claude-haiku-4-5-20251001"
    use_ollama: bool = False
    ollama_model: str = "llama3.2"
    ollama_url: str = "http://localhost:11434"
    use_openai: bool = False
    openai_model: str = "gpt-4o-mini"
    openai_url: Optional[str] = None
    openai_api_key: str = ""
    max_retries: int = 3
    context_lines: int = 3
    prompt_template: Optional[str] = None
    anthropic_api_key: str = ""


class GitConfigLoader:
    _KEYS = ["provider", "claudeModel", "ollamaModel", "ollamaUrl", "openaiModel", "openaiUrl", "prompt", "contextLines", "verify", "retries"]

    def load(self) -> dict[str, str]:
        cfg = {}
        for key in self._KEYS:
            result = subprocess.run(
                ["git", "config", "--get", f"reword.{key}"],
                capture_output=True, text=True,
            )
            if result.returncode == 0:
                cfg[key] = result.stdout.strip()
        return cfg


class CLIParser:
    def parse(self, argv: Optional[list[str]] = None) -> argparse.Namespace:
        if argv is None:
            argv = sys.argv[1:]

        checkpoint = bool(argv) and argv[0] == "checkpoint"
        if checkpoint:
            argv = argv[1:]

        parser = argparse.ArgumentParser(prog="git reword", description=__doc__)
        parser.add_argument("since", nargs="?", default=None, help="Commit range base (e.g. HEAD~5)")
        parser.add_argument("--auto", action="store_true", help="Auto-generate messages via AI")
        parser.add_argument("--claude", action="store_true", help="Use Claude (requires ANTHROPIC_API_KEY)")
        parser.add_argument("--claude-model", default=None, metavar="MODEL", help="Claude model name")
        parser.add_argument("--ollama", action="store_true", help="Use Ollama")
        parser.add_argument("--ollama-model", default=None, metavar="MODEL", help="Ollama model name")
        parser.add_argument("--openai", action="store_true", help="Use OpenAI (requires OPENAI_API_KEY)")
        parser.add_argument("--openai-model", default=None, metavar="MODEL", help="OpenAI model name")
        parser.add_argument("-v", "--verbose", action="count", default=0, help="Verbosity (-v AI output, -vvv also prompts)")
        parser.add_argument("--verify", action="store_true", help="Verify each message with a second AI call")
        args = parser.parse_args(argv)
        args.checkpoint = checkpoint
        return args


class ConfigFactory:
    def __init__(self, loader: GitConfigLoader):
        self._loader = loader

    def from_args(self, args: argparse.Namespace) -> Config:
        git_cfg = self._loader.load()
        default_provider = git_cfg.get("provider", "")

        use_ollama = args.ollama or "ollamaModel" in git_cfg or default_provider == "ollama"
        use_openai = args.openai or "openaiModel" in git_cfg or default_provider == "openai"
        use_claude = args.claude or "claudeModel" in git_cfg or default_provider == "claude"
        auto = args.auto or use_ollama or use_openai or use_claude

        return Config(
            since=args.since or "--root",
            auto=auto,
            checkpoint=args.checkpoint,
            verbosity=args.verbose,
            verify=args.verify or git_cfg.get("verify", "").lower() == "true",
            use_claude=use_claude,
            claude_model=args.claude_model or git_cfg.get("claudeModel", "claude-haiku-4-5-20251001"),
            use_ollama=use_ollama,
            ollama_model=args.ollama_model or git_cfg.get("ollamaModel", "llama3.2"),
            ollama_url=git_cfg.get("ollamaUrl", "http://localhost:11434"),
            use_openai=use_openai,
            openai_model=args.openai_model or git_cfg.get("openaiModel", "gpt-4o-mini"),
            openai_url=git_cfg.get("openaiUrl") or None,
            openai_api_key=os.environ.get("OPENAI_API_KEY", ""),
            max_retries=int(git_cfg.get("retries", 3)),
            context_lines=int(git_cfg.get("contextLines", 3)),
            prompt_template=git_cfg.get("prompt"),
            anthropic_api_key=os.environ.get("ANTHROPIC_API_KEY", ""),
        )


# ── Git client ─────────────────────────────────────────────────────────────────

class GitClient:
    def assert_in_repo(self) -> None:
        result = subprocess.run(["git", "rev-parse", "--git-dir"], capture_output=True)
        if result.returncode != 0:
            print("Error: not inside a git repository.", file=sys.stderr)
            sys.exit(1)

    def get_hashes(self, since: str) -> list[str]:
        cmd = ["git", "log", "--reverse", "--format=%H"]
        if since != "--root":
            cmd.append(f"{since}..HEAD")
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return [h for h in result.stdout.strip().splitlines() if h]

    def get_diff(self, commit_hash: str, context_lines: int) -> str:
        result = subprocess.run(
            ["git", "diff-tree", "--no-commit-id", "-p", f"-U{context_lines}", commit_hash],
            capture_output=True, text=True, check=True,
        )
        return result.stdout

    def get_stat(self, commit_hash: str) -> str:
        result = subprocess.run(
            ["git", "diff-tree", "--no-commit-id", "-r", "--stat", commit_hash],
            capture_output=True, text=True, check=True,
        )
        return result.stdout

    def get_original_message(self, commit_hash: str) -> str:
        result = subprocess.run(
            ["git", "log", "-1", "--format=%s", commit_hash],
            capture_output=True, text=True, check=True,
        )
        return result.stdout.strip()

    def rebase(self, since: str, messages: list[str], messages_file: Path) -> None:
        messages_file.write_text("\n".join(messages) + "\n")

        counter_file = Path(tempfile.mktemp())
        counter_file.write_text("0")

        seq_editor = Path(tempfile.mktemp(suffix=".py"))
        seq_editor.write_text(
            "#!/usr/bin/env python3\n"
            "import sys, re\n"
            "p = sys.argv[1]\n"
            "content = open(p).read()\n"
            "open(p, 'w').write(re.sub(r'^pick\\b', 'reword', content, flags=re.MULTILINE))\n"
        )
        seq_editor.chmod(seq_editor.stat().st_mode | stat.S_IEXEC)

        msg_editor = Path(tempfile.mktemp(suffix=".py"))
        msg_editor.write_text(
            "#!/usr/bin/env python3\n"
            "import sys\n"
            f"cf, mf = '{counter_file}', '{messages_file}'\n"
            "n = int(open(cf).read().strip()) + 1\n"
            "open(cf, 'w').write(str(n))\n"
            "lines = open(mf).read().splitlines()\n"
            "open(sys.argv[1], 'w').write((lines[n - 1] if n <= len(lines) else '') + '\\n')\n"
        )
        msg_editor.chmod(msg_editor.stat().st_mode | stat.S_IEXEC)

        try:
            cmd = ["git", "rebase", "-i"] + (["--root"] if since == "--root" else [since])
            subprocess.run(
                cmd,
                env={**os.environ, "GIT_SEQUENCE_EDITOR": str(seq_editor), "GIT_EDITOR": str(msg_editor)},
                check=True,
            )
        finally:
            for f in [counter_file, seq_editor, msg_editor]:
                f.unlink(missing_ok=True)


# ── Prompt builder ─────────────────────────────────────────────────────────────

class PromptBuilder:
    _DEFAULT = (
        "Generate a git commit message for the diff below.\n"
        "\n"
        "Rules (follow strictly):\n"
        "1. Start with an imperative verb: Add, Fix, Update, Remove, Refactor, Extract, Move, Rename, etc.\n"
        "2. Maximum 5 words total\n"
        "3. Describe the intent or effect, not the mechanism\n"
        "4. No filenames, variable names, function names, or code tokens\n"
        "5. No punctuation at the end\n"
        "\n"
        "Good examples:\n"
        "  Add user authentication\n"
        "  Fix null pointer crash\n"
        "  Remove deprecated endpoint\n"
        "  Refactor payment processing\n"
        "  Update error handling logic\n"
        "\n"
        "Diff:\n{diff}"
    )

    _VERIFY = (
        "Evaluate the proposed commit message against the diff.\n"
        "Return accurate=true only if ALL of the following hold:\n"
        "1. The message accurately describes what changed\n"
        "2. It starts with an imperative verb (Add, Fix, Update, Remove, Refactor, etc.)\n"
        "3. It is 5 words or fewer\n"
        "4. It contains no filenames, variable names, function names, or code tokens\n"
        "Otherwise return accurate=false.\n"
        "\n"
        "Proposed message: {message}\n\nDiff:\n{diff}"
    )

    def build(self, diff: str, template: Optional[str] = None) -> str:
        if template and "{diff}" not in template and not getattr(self, "_warned_diff", False):
            print("Warning: reword.prompt does not contain {diff} — the diff will not be included in the prompt.", file=sys.stderr)
            self._warned_diff = True
        return (template or self._DEFAULT).replace("{diff}", diff)

    def build_verify(self, message: str, diff: str) -> str:
        return self._VERIFY.replace("{message}", message).replace("{diff}", diff)


# ── AI providers ───────────────────────────────────────────────────────────────

class AIProvider(ABC):
    @property
    @abstractmethod
    def generate_system(self) -> str:
        """System message used for commit generation."""

    @property
    @abstractmethod
    def verify_system(self) -> str:
        """System message used for verification."""

    @abstractmethod
    def generate(self, prompt: str) -> dict:
        """Return structured commit message dict."""

    @abstractmethod
    def verify(self, prompt: str) -> dict:
        """Return structured verification dict."""


class OllamaProvider(AIProvider):
    _GENERATE_SYSTEM = (
        "You are a git commit message generator. "
        "Output only a short imperative commit message (≤5 words). "
        "No explanation, no chat, no preamble, no JSON wrapper."
    )
    _VERIFY_SYSTEM = (
        "You are a code reviewer. "
        "Evaluate whether the proposed commit message accurately describes the diff. "
        "Output only a JSON object with a boolean field."
    )

    def __init__(self, url: str, model: str):
        try:
            import ollama as _ollama
        except ImportError:
            print("Error: ollama package is required. Install with: pip install ollama", file=sys.stderr)
            sys.exit(1)
        self._ollama = _ollama
        self._model = model
        self._client = _ollama.Client(host=url, timeout=120)

    def check(self) -> None:
        try:
            self._client.list()
        except Exception:
            print(f"Error: Ollama is not running.\nStart with: ollama serve", file=sys.stderr)
            sys.exit(1)

    def _chat(self, prompt: str, schema: dict, system: str) -> dict:
        response = self._client.chat(
            model=self._model,
            format=schema,
            messages=[
                {"role": "system", "content": system},
                {"role": "user", "content": prompt},
            ],
        )
        return json.loads(response.message.content)

    @property
    def generate_system(self) -> str:
        return self._GENERATE_SYSTEM

    @property
    def verify_system(self) -> str:
        return self._VERIFY_SYSTEM

    def generate(self, prompt: str) -> dict:
        return self._chat(prompt, COMMIT_SCHEMA, self._GENERATE_SYSTEM)

    def verify(self, prompt: str) -> dict:
        return self._chat(prompt, VERIFY_SCHEMA, self._VERIFY_SYSTEM)


class ClaudeProvider(AIProvider):
    _GENERATE_SYSTEM = (
        "You are a git commit message generator. "
        "Output only a short imperative commit message (≤5 words) via the tool. "
        "No explanation, no chat, no preamble."
    )
    _VERIFY_SYSTEM = (
        "You are a code reviewer. "
        "Evaluate whether the proposed commit message accurately describes the diff. "
        "Use the tool to return your answer."
    )

    def __init__(self, api_key: str, model: str):
        if not api_key:
            print("Error: ANTHROPIC_API_KEY is not set.", file=sys.stderr)
            sys.exit(1)
        try:
            import anthropic as _anthropic
        except ImportError:
            print("Error: anthropic package is required. Install with: pip install anthropic", file=sys.stderr)
            sys.exit(1)
        self._client = _anthropic.Anthropic(api_key=api_key)
        self._model = model

    def _call(self, prompt: str, schema: dict, tool_name: str, max_tokens: int, system: str) -> dict:
        response = self._client.messages.create(
            model=self._model,
            max_tokens=max_tokens,
            system=system,
            tools=[{"name": tool_name, "description": tool_name, "input_schema": schema}],
            tool_choice={"type": "tool", "name": tool_name},
            messages=[{"role": "user", "content": prompt}],
        )
        return response.content[0].input

    @property
    def generate_system(self) -> str:
        return self._GENERATE_SYSTEM

    @property
    def verify_system(self) -> str:
        return self._VERIFY_SYSTEM

    def generate(self, prompt: str) -> dict:
        return self._call(prompt, COMMIT_SCHEMA, "commit", max_tokens=64, system=self._GENERATE_SYSTEM)

    def verify(self, prompt: str) -> dict:
        return self._call(prompt, VERIFY_SCHEMA, "verify", max_tokens=16, system=self._VERIFY_SYSTEM)


class OpenAIProvider(AIProvider):
    _GENERATE_SYSTEM = (
        "You are a git commit message generator. "
        "Output only a short imperative commit message (≤5 words). "
        "No explanation, no chat, no preamble."
    )
    _VERIFY_SYSTEM = (
        "You are a code reviewer. "
        "Evaluate whether the proposed commit message accurately describes the diff. "
        "Return your answer as JSON."
    )

    def __init__(self, api_key: str, model: str, base_url: Optional[str] = None):
        if not api_key:
            print("Error: OPENAI_API_KEY is not set.", file=sys.stderr)
            sys.exit(1)
        try:
            import openai as _openai
        except ImportError:
            print("Error: openai package is required. Install with: pip install openai", file=sys.stderr)
            sys.exit(1)
        self._client = _openai.OpenAI(api_key=api_key, **({"base_url": base_url} if base_url else {}))
        self._model = model

    def _call(self, prompt: str, schema: dict, system: str) -> dict:
        response = self._client.chat.completions.create(
            model=self._model,
            response_format={
                "type": "json_schema",
                "json_schema": {"name": "response", "strict": True, "schema": schema},
            },
            messages=[
                {"role": "system", "content": system},
                {"role": "user", "content": prompt},
            ],
        )
        return json.loads(response.choices[0].message.content)

    @property
    def generate_system(self) -> str:
        return self._GENERATE_SYSTEM

    @property
    def verify_system(self) -> str:
        return self._VERIFY_SYSTEM

    def generate(self, prompt: str) -> dict:
        return self._call(prompt, COMMIT_SCHEMA, self._GENERATE_SYSTEM)

    def verify(self, prompt: str) -> dict:
        return self._call(prompt, VERIFY_SCHEMA, self._VERIFY_SYSTEM)


class ProviderFactory:
    def create(self, config: Config) -> AIProvider:
        if config.use_openai:
            return OpenAIProvider(config.openai_api_key, config.openai_model, config.openai_url)
        if config.use_ollama:
            provider = OllamaProvider(config.ollama_url, config.ollama_model)
            provider.check()
            return provider
        if config.use_claude:
            return ClaudeProvider(config.anthropic_api_key, config.claude_model)
        print("Error: no provider selected. Use --claude, --openai, or --ollama (or set reword.* git config).", file=sys.stderr)
        sys.exit(1)


# ── Message generator ──────────────────────────────────────────────────────────

class MessageGenerator:
    def __init__(self, provider: AIProvider, prompt_builder: PromptBuilder, config: Config):
        self._provider = provider
        self._prompt_builder = prompt_builder
        self._config = config

    def generate(self, commit_hash: str, diff: str) -> Optional[str]:
        prompt = self._prompt_builder.build(diff, self._config.prompt_template)
        if self._config.verbosity >= 3:
            print(f"  [prompt:system] {commit_hash[:7]}: {self._provider.generate_system}", file=sys.stderr)
            print(f"  [prompt:user] {commit_hash[:7]}:\n{prompt}", file=sys.stderr)
        try:
            result = self._provider.generate(prompt)
            raw = result.get("message", "").strip()
            lines = [l.strip() for l in raw.splitlines() if l.strip()]
            msg = lines[0].strip("`'\"") if lines else ""
            if self._config.verbosity >= 1:
                print(f"  [debug] {commit_hash[:7]}: {msg}", file=sys.stderr)
            return msg or None
        except Exception as exc:
            if self._config.verbosity >= 1:
                print(f"  [debug] {commit_hash[:7]}: error — {exc}", file=sys.stderr)
            return None


# ── Message verifier ───────────────────────────────────────────────────────────

class MessageVerifier:
    def __init__(self, provider: AIProvider, prompt_builder: PromptBuilder, config: Config):
        self._provider = provider
        self._prompt_builder = prompt_builder
        self._config = config

    def verify(self, message: str, diff: str, commit_hash: str = "") -> bool:
        prompt = self._prompt_builder.build_verify(message, diff)
        if self._config.verbosity >= 3:
            prefix = f" {commit_hash[:7]}" if commit_hash else ""
            print(f"  [verify-prompt:system]{prefix}: {self._provider.verify_system}", file=sys.stderr)
            print(f"  [verify-prompt:user]{prefix}:\n{prompt}", file=sys.stderr)
        try:
            result = self._provider.verify(prompt)
            return bool(result.get("accurate", True))
        except Exception:
            return True  # fail open


# ── Checkpoint generator ───────────────────────────────────────────────────────

class CheckpointGenerator:
    _PATTERN = re.compile(r"^Checkpoint #(\d+)$", re.IGNORECASE)

    def __init__(self, git: GitClient):
        self._git = git

    def _max_existing(self) -> int:
        result = subprocess.run(
            ["git", "log", "--format=%s"],
            capture_output=True, text=True, check=True,
        )
        max_n = 0
        for line in result.stdout.splitlines():
            m = self._PATTERN.match(line.strip())
            if m:
                max_n = max(max_n, int(m.group(1)))
        return max_n

    def generate(self, count: int) -> list[str]:
        start = self._max_existing() + 1
        return [f"Checkpoint #{start + i}" for i in range(count)]


# ── Reword orchestrator ────────────────────────────────────────────────────────

class Reworder:
    def __init__(
        self,
        git: GitClient,
        config: Config,
        generator: Optional[MessageGenerator] = None,
        verifier: Optional[MessageVerifier] = None,
    ):
        self._git = git
        self._config = config
        self._generator = generator
        self._verifier = verifier

    def run(self) -> None:
        hashes = self._git.get_hashes(self._config.since)
        if not hashes:
            print("No commits to reword.")
            return

        count = len(hashes)
        print(f"Rewording {count} commit(s)...")

        if self._config.checkpoint:
            messages = CheckpointGenerator(self._git).generate(count)
        elif self._config.auto:
            messages = self._auto_mode(hashes)
        else:
            messages = self._interactive_mode(hashes)
        self._confirm_and_apply(hashes, messages)

    def _auto_mode(self, hashes: list[str]) -> list[str]:
        messages = []
        count = len(hashes)
        for i, commit_hash in enumerate(hashes, 1):
            print(f"  [{i}/{count}] {commit_hash[:7]}")
            messages.append(self._generate_with_retry(commit_hash))
        return messages

    def _generate_with_retry(self, commit_hash: str) -> str:
        diff = self._git.get_diff(commit_hash, self._config.context_lines)
        msg = (self._generator.generate(commit_hash, diff)
               or self._git.get_original_message(commit_hash))

        if not self._verifier:
            return msg

        attempt = 0
        while not self._verifier.verify(msg, diff, commit_hash):
            if self._config.verbosity >= 1:
                print(f"  [verify] {commit_hash[:7]}: rejected (attempt {attempt + 1}/{self._config.max_retries})", file=sys.stderr)
            if attempt >= self._config.max_retries:
                if self._config.verbosity >= 1:
                    print(f"  [verify] {commit_hash[:7]}: max retries reached → keeping original", file=sys.stderr)
                return self._git.get_original_message(commit_hash)
            attempt += 1
            ctx = self._config.context_lines * (attempt + 1)
            if self._config.verbosity >= 1:
                print(f"  [verify] {commit_hash[:7]}: retrying with {ctx} context lines", file=sys.stderr)
            diff = self._git.get_diff(commit_hash, ctx)
            msg = (self._generator.generate(commit_hash, diff)
                   or self._git.get_original_message(commit_hash))

        if self._config.verbosity >= 1:
            print(f"  [verify] {commit_hash[:7]}: accurate", file=sys.stderr)
        return msg

    def _interactive_mode(self, hashes: list[str]) -> list[str]:
        messages = []
        for commit_hash in hashes:
            print("\n──────────────────────────────────────────")
            print(f"Commit: {commit_hash[:7]}")
            print(f"Current: {self._git.get_original_message(commit_hash)}")
            print()
            print(self._git.get_stat(commit_hash))
            msg = input("New message (≤5 words, blank = keep): ").strip()
            messages.append(msg or self._git.get_original_message(commit_hash))
        return messages

    def _confirm_and_apply(self, hashes: list[str], messages: list[str]) -> None:
        print("\nGenerated messages:")
        print("───────────────────")
        for commit_hash, msg in zip(hashes, messages):
            print(f"  {commit_hash[:7]}  {msg}")
        print()

        confirm = input("Apply these messages? [Y/n] ").strip().lower()
        if confirm == "n":
            print("Aborted.")
            return

        with tempfile.NamedTemporaryFile(mode="w", suffix=".txt", delete=False) as f:
            messages_file = Path(f.name)
        try:
            self._git.rebase(self._config.since, messages, messages_file)
            print(f"\nDone. {len(messages)} commit(s) reworded.")
        finally:
            messages_file.unlink(missing_ok=True)


# ── Entry point ────────────────────────────────────────────────────────────────

def main() -> None:
    args = CLIParser().parse()
    git = GitClient()
    git.assert_in_repo()

    config = ConfigFactory(GitConfigLoader()).from_args(args)

    generator: Optional[MessageGenerator] = None
    verifier: Optional[MessageVerifier] = None

    if config.auto and not config.checkpoint:
        provider = ProviderFactory().create(config)
        prompt_builder = PromptBuilder()
        generator = MessageGenerator(provider, prompt_builder, config)
        if config.verify:
            verifier = MessageVerifier(provider, prompt_builder, config)

    Reworder(git, config, generator, verifier).run()


if __name__ == "__main__":
    main()
