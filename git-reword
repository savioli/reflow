#!/usr/bin/env python3
"""git-reword — reword commit messages interactively or via AI.

Subcommands:
  checkpoint            commit staged changes as Checkpoint #N (continues enumeration)

Examples:
  Interactive (branch commits only by default):
    git reword                          reword branch commits interactively
    git reword HEAD~5                   reword last 5 commits interactively

  Auto mode (requires a provider flag or reword.provider git config):
    git reword --auto --claude          auto-generate via Claude
    git reword --auto --openai          auto-generate via OpenAI
    git reword --auto --ollama          auto-generate via Ollama
    git reword HEAD~5 --auto --claude   auto mode on explicit range

  Branch rename:
    git reword --branch --claude        generate and rename current branch via Claude
    git rw -b --openai                  short form
    git rw -b --claude --prefix feature force a branch prefix

  Checkpoint:
    git reword checkpoint               commit staged changes as Checkpoint #N
    git ck                              short alias

  Flags:
    --auto                              auto-generate messages via AI
    --branch / -b                       generate and rename current branch
    --prefix PREFIX                     prefix for branch name (e.g. feature, fix, chore)
    --verify                            verify each message with a second AI call
    -v / -vvv                           verbosity (AI output / + prompts)

  Provider flags:
    --claude                            use Claude (requires ANTHROPIC_API_KEY)
    --openai                            use OpenAI (requires OPENAI_API_KEY)
    --ollama                            use Ollama

  Provider model overrides:
    --claude-model MODEL                Claude model name
    --openai-model MODEL                OpenAI model name
    --ollama-model MODEL                Ollama model name

Git config (per-repo defaults):
  reword.provider           claude | openai | ollama
  reword.claudeModel        model name for Claude
  reword.openaiModel        model name for OpenAI
  reword.ollamaModel        model name for Ollama
  reword.ollamaUrl          Ollama base URL (default: http://localhost:11434)
  reword.contextLines       diff context lines for commit rewording (default: 3)
  reword.branchContextLines diff context lines for branch naming (default: 3)
  reword.branchPrefix       default prefix for generated branch names
  reword.verify             true to verify each message with a second AI call
  reword.retries            max verification retries (default: 3)
  reword.prompt             custom prompt template (must include {diff})

API keys (env vars):
  ANTHROPIC_API_KEY         required for --claude
  OPENAI_API_KEY            required for --openai
"""

import argparse
import json
import os
import re
import stat
import subprocess
import sys
import tempfile
from abc import ABC, abstractmethod
from dataclasses import dataclass
from pathlib import Path
from typing import Optional


